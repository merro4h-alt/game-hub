rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'kmerro25@gmail.com' ||
        request.auth.token.email == 'merro4h@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Products: Everyone can read, only Admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins collection: Only Admins can read/write
    match /admins/{userId} {
      allow read, write: if isAdmin();
    }

    // Users: Users can read/write their own profile
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
